{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node ./node_modules/@yao-pkg/pkg/lib-es5/bin.js . --targets node24-win-x64 --out-path dist",
    "build:win": "node ./node_modules/@yao-pkg/pkg/lib-es5/bin.js . --targets node24-win-x64 --out-path dist",
    "build:linux": "node ./node_modules/@yao-pkg/pkg/lib-es5/bin.js . --targets node24-linux-x64 --out-path dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "pkg": {
    "scripts": "build/**/*.js",
    "assets": [
      "views/**/*",
      "public/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ],
    "targets": [
      "node24-win-x64",
      "node24-linux-x64"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "multer": "^2.2.0",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.8.3",
    "spatialite": "^0.1.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "6.16.0"
  }
}
